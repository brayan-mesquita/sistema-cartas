# Copie para `.env` e preencha os valores. NUNCA commite valores reais aqui —
# este arquivo é versionado e público.

# ==========================================
# CONFIGURAÇÕES DO SERVIDOR & BANCO SQLITE
# ==========================================
NODE_ENV=development
PORT=3000

# URL pública da aplicação. ATENÇÃO: também precisa ser passada como
# Build Argument no Docker/Easypanel — o metadata da home é estático e as tags
# og:image são resolvidas durante o build, não em runtime.
NEXT_PUBLIC_APP_URL=

DATABASE_URL="file:./data/legendarios.db"

# ==========================================
# ARMAZENAMENTO: GOOGLE DRIVE API EXCLUSIVO
# ==========================================
# ID da pasta no Google Drive onde as cartas serão salvas
GOOGLE_DRIVE_FOLDER_ID=

# --- OPÇÃO A: SERVICE ACCOUNT (Google Workspace) ---
GOOGLE_SERVICE_ACCOUNT_JSON="./service-account.json"

# --- OPÇÃO B: OAUTH 2.0 REFRESH TOKEN (Gmail Pessoal @gmail.com) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ==========================================
# PAINEL DE ADMINISTRAÇÃO
# ==========================================
# Obrigatório. Sem esta variável, o login do admin é desativado.
ADMIN_PASSWORD=

# Obrigatório. Segredo usado para assinar o cookie de sessão do admin.
# Gere com: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ==========================================
# INTEGRAÇÃO CRM GO HIGH LEVEL (GHL)
# ==========================================
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_CARTAS_FIELD_ID=
